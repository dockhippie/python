FROM ghcr.io/dockhippie/alpine:latest-amd64@sha256:b8c8a2164aa640092a989d87ae81f820d69de2f9d24134ca2f4223877487ccd5

WORKDIR /srv/app

RUN apk update && \
  apk upgrade && \
  apk add build-base openssl-dev libffi-dev git python3-dev python3 py3-pip py3-tox && \
  rm -rf /var/cache/apk/*

COPY ./overlay /

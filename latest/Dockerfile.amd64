FROM ghcr.io/dockhippie/alpine:latest-amd64@sha256:ef60e205e8eb111fd82b3b81f9741b69a62a4e096fe12588dabe850987193673

WORKDIR /srv/app

RUN apk update && \
  apk upgrade && \
  apk add build-base openssl-dev libffi-dev git python3-dev python3 py3-pip py3-tox && \
  rm -rf /var/cache/apk/*

COPY ./overlay /

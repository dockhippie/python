FROM ghcr.io/dockhippie/alpine:latest-amd64@sha256:3654fee32bf6e7801421abec274f7440067db343562634d3ab0424b35dc1a459

WORKDIR /srv/app

RUN apk update && \
  apk upgrade && \
  apk add build-base openssl-dev libffi-dev git python3-dev python3 py3-pip py3-tox && \
  rm -rf /var/cache/apk/*

COPY ./overlay /

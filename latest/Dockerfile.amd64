FROM ghcr.io/dockhippie/alpine:latest-amd64@sha256:4cfa465f4a067369439dc55d645cfc52909cb46a6a94856e3162e7fd5a9465b2

WORKDIR /srv/app

RUN apk update && \
  apk upgrade && \
  apk add build-base openssl-dev libffi-dev git python3-dev python3 py3-pip py3-tox && \
  rm -rf /var/cache/apk/*

COPY ./overlay /

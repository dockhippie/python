FROM ghcr.io/dockhippie/alpine:latest-amd64@sha256:6ff71f40247b9ad7d7d1ca038635bc783bce7bb9eae66527f70bfd8fca025965

WORKDIR /srv/app

RUN apk update && \
  apk upgrade && \
  apk add build-base openssl-dev libffi-dev git python3-dev python3 py3-pip py3-tox && \
  rm -rf /var/cache/apk/*

COPY ./overlay /

FROM ghcr.io/dockhippie/alpine:latest-amd64@sha256:ef4289b793c6e795ffef683dfef53bca95e3d399a05306d56633f86fddd8437b

WORKDIR /srv/app

RUN apk update && \
  apk upgrade && \
  apk add build-base openssl-dev libffi-dev git python3-dev python3 py3-pip py3-tox && \
  rm -rf /var/cache/apk/*

COPY ./overlay /

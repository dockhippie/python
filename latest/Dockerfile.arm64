FROM ghcr.io/dockhippie/alpine:latest-arm64@sha256:9a26a5670a11ca47049dc53cad3b012074b038bd0e4c59af8c92f81be4d5defb

WORKDIR /srv/app

RUN apk update && \
  apk upgrade && \
  apk add build-base openssl-dev libffi-dev git python3-dev python3 py3-pip py3-tox && \
  rm -rf /var/cache/apk/*

COPY ./overlay /

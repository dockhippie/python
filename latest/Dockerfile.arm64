FROM ghcr.io/dockhippie/alpine:latest-arm64@sha256:c778aebac9177eb9d4f3d7baad5ee89e60d3e423797feb6dcd5a5cd88e6be16d

WORKDIR /srv/app

RUN apk update && \
  apk upgrade && \
  apk add build-base openssl-dev libffi-dev git python3-dev python3 py3-pip py3-tox && \
  rm -rf /var/cache/apk/*

COPY ./overlay /

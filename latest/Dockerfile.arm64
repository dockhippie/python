FROM ghcr.io/dockhippie/alpine:latest-arm64@sha256:e2917e86e92c034b510c41cd3bdb598a3fe8dfca8be5bce1b8b73c0d06da1eff

WORKDIR /srv/app

RUN apk update && \
  apk upgrade && \
  apk add build-base openssl-dev libffi-dev git python3-dev python3 py3-pip py3-tox && \
  rm -rf /var/cache/apk/*

COPY ./overlay /

FROM ghcr.io/dockhippie/alpine:latest-arm64@sha256:cf9a331a57489320224a2c9692a2659c999f3dba3bf6fe2a4f1ccaa9d9935e35

WORKDIR /srv/app

RUN apk update && \
  apk upgrade && \
  apk add build-base openssl-dev libffi-dev git python3-dev python3 py3-pip py3-tox && \
  rm -rf /var/cache/apk/*

COPY ./overlay /

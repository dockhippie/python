FROM ghcr.io/dockhippie/alpine:latest-arm@sha256:96935222d1aa3a341e482006a8785a83c2b6dfff4821e433fe694ff733b38d41

WORKDIR /srv/app

RUN apk update && \
  apk upgrade && \
  apk add build-base openssl-dev libffi-dev git python3-dev python3 py3-pip py3-tox && \
  rm -rf /var/cache/apk/*

COPY ./overlay /

FROM ghcr.io/dockhippie/alpine:latest-arm@sha256:c4b2fdf3f0038145ae5a9a4ce399ba885d3797ce3526962a0be7cae57e09db70

WORKDIR /srv/app

RUN apk update && \
  apk upgrade && \
  apk add build-base openssl-dev libffi-dev git python3-dev python3 py3-pip py3-tox && \
  rm -rf /var/cache/apk/*

COPY ./overlay /
